@page
@model IndexModel
@{
    ViewData["Title"] = L["Home"].Value;
}

<div class="space-y-12">
    <!-- Hero -->
    <section class="text-center py-12">
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-4">@L["HeroTitle"]</h1>
        <p class="text-lg text-gray-500 dark:text-slate-400 mb-8">@L["HeroSubtitle"]</p>
        <a asp-page="/Products/Index" class="inline-block bg-indigo-500 hover:bg-indigo-600 text-white font-semibold px-8 py-3 rounded-lg transition">
            @L["ShopNow"]
        </a>
    </section>

    <!-- Categories -->
    <section>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">@L["ShopByCategory"]</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            @foreach (var category in Model.Categories)
            {
                <a asp-page="/Products/Index" asp-route-category="@category.Slug"
                   class="bg-white dark:bg-slate-800 hover:bg-gray-50 dark:hover:bg-slate-700 border border-gray-200 dark:border-slate-700 rounded-lg p-6 text-center transition">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white">@category.Name</h3>
                    <p class="text-sm text-gray-500 dark:text-slate-400 mt-1">@category.Description</p>
                </a>
            }
        </div>
    </section>

    <!-- Featured Products -->
    <section>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">@L["FeaturedProducts"]</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var product in Model.FeaturedProducts)
            {
                <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg overflow-hidden hover:border-indigo-500 transition">
                    <div class="h-48 bg-gray-100 dark:bg-slate-700 flex items-center justify-center">
                        <svg class="w-16 h-16 text-gray-300 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                    </div>
                    <div class="p-4">
                        <span class="text-xs text-indigo-600 dark:text-indigo-400 font-medium">@product.Category.Name</span>
                        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mt-1">@product.Name</h3>
                        <p class="text-sm text-gray-500 dark:text-slate-400 mt-1 line-clamp-2">@product.Description</p>
                        <div class="flex items-center justify-between mt-4">
                            <span class="text-xl font-bold text-emerald-600 dark:text-emerald-400">$@product.Price.ToString("F2")</span>
                            <span class="text-xs px-2 py-1 rounded bg-gray-100 dark:bg-slate-700 text-gray-600 dark:text-slate-300">
                                @(product.ProductType == aspshop.Models.ProductType.Digital ? L["Digital"].Value : L["Physical"].Value)
                            </span>
                        </div>
                        <div class="flex gap-2 mt-3">
                            <a asp-page="/Products/Detail" asp-route-id="@product.Id"
                               class="flex-1 text-center text-sm border border-gray-300 dark:border-slate-600 hover:border-gray-400 dark:hover:border-slate-500 text-gray-600 dark:text-slate-300 py-2 rounded-lg transition">
                                @L["Details"]
                            </a>
                            <form method="post" asp-page-handler="AddToCart" class="flex-1">
                                <input type="hidden" name="productId" value="@product.Id" />
                                <button type="submit"
                                        class="w-full text-sm bg-indigo-500 hover:bg-indigo-600 text-white py-2 rounded-lg transition">
                                    @L["AddToCart"]
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
</div>
