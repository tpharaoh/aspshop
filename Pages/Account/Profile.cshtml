@page
@model aspshop.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="max-w-2xl mx-auto space-y-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">My Profile</h1>

    @if (Model.SuccessMessage != null)
    {
        <div class="bg-emerald-500/10 border border-emerald-500 text-emerald-600 dark:text-emerald-400 rounded-lg p-3 text-sm">@Model.SuccessMessage</div>
    }

    <form method="post" class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 space-y-4">
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">First Name</label>
                <input asp-for="Input.FirstName" class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500" />
            </div>
            <div>
                <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">Last Name</label>
                <input asp-for="Input.LastName" class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500" />
            </div>
        </div>
        <div>
            <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">Email</label>
            <input value="@Model.Email" disabled class="w-full bg-gray-100 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-400 dark:text-slate-500 rounded-lg px-4 py-2 text-sm" />
        </div>
        <button type="submit" class="bg-indigo-500 hover:bg-indigo-600 text-white font-semibold px-6 py-2 rounded-lg transition">
            Save Changes
        </button>
    </form>
</div>
