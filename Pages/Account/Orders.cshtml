@page
@model aspshop.Pages.Account.OrdersModel
@{
    ViewData["Title"] = "My Orders";
}

<div class="max-w-4xl mx-auto space-y-6">
    <h1 class="text-3xl font-bold text-white">My Orders</h1>

    @if (!Model.Orders.Any())
    {
        <div class="text-center py-12">
            <p class="text-slate-400">You haven't placed any orders yet.</p>
            <a asp-page="/Products/Index" class="text-indigo-400 hover:text-indigo-300 mt-2 inline-block">Browse Products</a>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var order in Model.Orders)
            {
                <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <span class="text-white font-semibold">Order #@order.Id</span>
                            <span class="text-slate-400 text-sm ml-4">@order.OrderDate.ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="flex items-center gap-4">
                            <span class="text-sm px-3 py-1 rounded-full bg-slate-700 text-slate-300">@order.Status</span>
                            <span class="text-emerald-400 font-bold">$@order.TotalAmount.ToString("F2")</span>
                        </div>
                    </div>
                    <div class="space-y-2">
                        @foreach (var item in order.OrderItems)
                        {
                            <div class="flex justify-between text-sm">
                                <span class="text-slate-300">@item.Product.Name x @item.Quantity</span>
                                <span class="text-slate-400">$@((item.UnitPrice * item.Quantity).ToString("F2"))</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
