@page
@model aspshop.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="space-y-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Admin Dashboard</h1>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6">
            <p class="text-sm text-gray-500 dark:text-slate-400">Total Products</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mt-1">@Model.ProductCount</p>
        </div>
        <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6">
            <p class="text-sm text-gray-500 dark:text-slate-400">Categories</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mt-1">@Model.CategoryCount</p>
        </div>
        <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6">
            <p class="text-sm text-gray-500 dark:text-slate-400">Total Orders</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mt-1">@Model.OrderCount</p>
        </div>
        <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6">
            <p class="text-sm text-gray-500 dark:text-slate-400">Users</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mt-1">@Model.UserCount</p>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a asp-page="/Admin/Products/Index" class="bg-indigo-500/10 border border-indigo-500/30 hover:border-indigo-500 rounded-lg p-6 text-center transition">
            <h3 class="text-lg font-semibold text-indigo-600 dark:text-indigo-400">Manage Products</h3>
            <p class="text-sm text-gray-500 dark:text-slate-400 mt-1">Add, edit, delete products</p>
        </a>
        <a asp-page="/Admin/Categories/Index" class="bg-emerald-500/10 border border-emerald-500/30 hover:border-emerald-500 rounded-lg p-6 text-center transition">
            <h3 class="text-lg font-semibold text-emerald-600 dark:text-emerald-400">Manage Categories</h3>
            <p class="text-sm text-gray-500 dark:text-slate-400 mt-1">Organize your catalog</p>
        </a>
        <a asp-page="/Admin/Orders/Index" class="bg-amber-500/10 border border-amber-500/30 hover:border-amber-500 rounded-lg p-6 text-center transition">
            <h3 class="text-lg font-semibold text-amber-600 dark:text-amber-400">Manage Orders</h3>
            <p class="text-sm text-gray-500 dark:text-slate-400 mt-1">View and update orders</p>
        </a>
    </div>
</div>
