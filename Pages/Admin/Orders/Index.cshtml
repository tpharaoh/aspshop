@page
@model aspshop.Pages.Admin.Orders.IndexModel
@{
    ViewData["Title"] = "Manage Orders";
}

<div class="space-y-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Orders</h1>

    @if (!Model.Orders.Any())
    {
        <div class="text-center py-12">
            <p class="text-gray-500 dark:text-slate-400">No orders yet.</p>
        </div>
    }
    else
    {
        <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg overflow-hidden">
            <table class="w-full">
                <thead class="bg-gray-50 dark:bg-slate-700">
                    <tr>
                        <th class="text-left text-sm font-medium text-gray-600 dark:text-slate-300 px-4 py-3">Order #</th>
                        <th class="text-left text-sm font-medium text-gray-600 dark:text-slate-300 px-4 py-3">Customer</th>
                        <th class="text-left text-sm font-medium text-gray-600 dark:text-slate-300 px-4 py-3">Date</th>
                        <th class="text-left text-sm font-medium text-gray-600 dark:text-slate-300 px-4 py-3">Total</th>
                        <th class="text-left text-sm font-medium text-gray-600 dark:text-slate-300 px-4 py-3">Status</th>
                        <th class="text-right text-sm font-medium text-gray-600 dark:text-slate-300 px-4 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-slate-700">
                    @foreach (var order in Model.Orders)
                    {
                        <tr class="hover:bg-gray-50 dark:hover:bg-slate-700/50">
                            <td class="px-4 py-3 text-gray-900 dark:text-white">#@order.Id</td>
                            <td class="px-4 py-3 text-gray-500 dark:text-slate-400">@order.User.Email</td>
                            <td class="px-4 py-3 text-gray-500 dark:text-slate-400">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td class="px-4 py-3 text-emerald-600 dark:text-emerald-400">$@order.TotalAmount.ToString("F2")</td>
                            <td class="px-4 py-3">
                                <form method="post" asp-page-handler="UpdateStatus" class="flex items-center gap-2">
                                    <input type="hidden" name="orderId" value="@order.Id" />
                                    <select name="status" class="bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded px-2 py-1 text-xs">
                                        @foreach (var status in Enum.GetValues<aspshop.Models.OrderStatus>())
                                        {
                                            <option value="@status" selected="@(order.Status == status)">@status</option>
                                        }
                                    </select>
                                    <button type="submit" class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300 text-xs">Update</button>
                                </form>
                            </td>
                            <td class="px-4 py-3 text-right text-sm text-gray-500 dark:text-slate-400">
                                @order.OrderItems.Count items
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
