@page
@model aspshop.Pages.Admin.Products.CreateModel
@{
    ViewData["Title"] = "Add Product";
}

<div class="max-w-2xl mx-auto space-y-6">
    <a asp-page="/Admin/Products/Index" class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300 text-sm">&larr; Back to products</a>
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Add Product</h1>

    <form method="post" class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 space-y-4">
        <div>
            <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">Name</label>
            <input asp-for="Input.Name" class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500" />
        </div>
        <div>
            <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">Description</label>
            <textarea asp-for="Input.Description" rows="3" class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">Price</label>
                <input asp-for="Input.Price" type="number" step="0.01" class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500" />
            </div>
            <div>
                <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">Category</label>
                <select asp-for="Input.CategoryId" asp-items="Model.CategoryOptions" class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500"></select>
            </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">Product Type</label>
                <select asp-for="Input.ProductType" asp-items="Html.GetEnumSelectList<aspshop.Models.ProductType>()" class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500"></select>
            </div>
            <div>
                <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">Stock Quantity</label>
                <input asp-for="Input.StockQuantity" type="number" class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500" />
            </div>
        </div>
        <div>
            <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">Image URL</label>
            <input asp-for="Input.ImageUrl" class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500" />
        </div>
        <button type="submit" class="bg-indigo-500 hover:bg-indigo-600 text-white font-semibold px-6 py-2 rounded-lg transition">
            Create Product
        </button>
    </form>
</div>
