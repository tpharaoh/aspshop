@using aspshop.Services
@inject CartService Cart
<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EShop</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="h-full bg-slate-900 text-slate-100">
    <div class="min-h-full flex flex-col">
        <nav class="bg-slate-800 border-b border-slate-700">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between h-16">
                    <div class="flex items-center gap-8">
                        <a asp-page="/Index" class="text-xl font-bold text-indigo-400">EShop</a>
                        <div class="hidden sm:flex gap-4">
                            <a asp-page="/Index" class="text-slate-300 hover:text-white px-3 py-2 text-sm font-medium">Home</a>
                            <a asp-page="/Products/Index" class="text-slate-300 hover:text-white px-3 py-2 text-sm font-medium">Products</a>
                            <a asp-page="/Admin/Index" class="text-slate-300 hover:text-white px-3 py-2 text-sm font-medium">Admin</a>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <a asp-page="/Cart/Index" class="text-slate-300 hover:text-white relative flex items-center gap-1">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
                            </svg>
                            @{
                                var cartCount = Cart.GetCartCount();
                            }
                            @if (cartCount > 0)
                            {
                                <span class="bg-indigo-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center">@cartCount</span>
                            }
                        </a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-page="/Account/Profile" class="text-slate-300 hover:text-white text-sm font-medium">Profile</a>
                            <a asp-page="/Account/Orders" class="text-slate-300 hover:text-white text-sm font-medium">Orders</a>
                            <form method="post" asp-page="/Account/Logout" class="inline">
                                <button type="submit" class="text-slate-300 hover:text-white text-sm font-medium">Logout</button>
                            </form>
                        }
                        else
                        {
                            <a asp-page="/Account/Login" class="text-slate-300 hover:text-white text-sm font-medium">Login</a>
                            <a asp-page="/Account/Register" class="bg-indigo-500 hover:bg-indigo-600 text-white text-sm font-medium px-3 py-1.5 rounded-lg transition">Register</a>
                        }
                    </div>
                </div>
            </div>
        </nav>

        <main class="flex-1">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
                @RenderBody()
            </div>
        </main>

        <footer class="bg-slate-800 border-t border-slate-700">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
                <p class="text-center text-slate-400 text-sm">&copy; 2026 EShop - ASP.NET Core Learning Project</p>
            </div>
        </footer>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
