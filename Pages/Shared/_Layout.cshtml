@using aspshop.Services
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.AspNetCore.Localization
@inject CartService Cart
@inject IViewLocalizer Localizer
@inject IHtmlLocalizer<aspshop.SharedResource> L
<!DOCTYPE html>
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.UICulture.TwoLetterISOLanguageName ?? "en";
    var isRtl = currentCulture == "ar";
}
<html lang="@currentCulture" dir="@(isRtl ? "rtl" : "ltr")" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EShop</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        // Apply theme before paint to prevent flash
        if (localStorage.getItem('theme') === 'light') {
            document.documentElement.classList.remove('dark');
        } else if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark');
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
            document.documentElement.classList.remove('dark');
        } else {
            document.documentElement.classList.add('dark');
        }
    </script>
</head>
<body class="h-full bg-gray-50 text-gray-900 dark:bg-slate-900 dark:text-slate-100 transition-colors duration-300">
    <div class="min-h-full flex flex-col">
        <nav class="bg-white dark:bg-slate-800 border-b border-gray-200 dark:border-slate-700 transition-colors duration-300">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between h-16">
                    <div class="flex items-center gap-8">
                        <a asp-page="/Index" class="text-xl font-bold text-indigo-600 dark:text-indigo-400">EShop</a>
                        <div class="hidden sm:flex gap-4">
                            <a asp-page="/Index" class="text-gray-600 dark:text-slate-300 hover:text-gray-900 dark:hover:text-white px-3 py-2 text-sm font-medium">@L["Home"]</a>
                            <a asp-page="/Products/Index" class="text-gray-600 dark:text-slate-300 hover:text-gray-900 dark:hover:text-white px-3 py-2 text-sm font-medium">@L["Products"]</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-page="/Admin/Index" class="text-gray-600 dark:text-slate-300 hover:text-gray-900 dark:hover:text-white px-3 py-2 text-sm font-medium">@L["Admin"]</a>
                            }
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <!-- Language Switcher -->
                        <div class="relative" id="lang-menu">
                            <button type="button" onclick="document.getElementById('lang-dropdown').classList.toggle('hidden')"
                                    class="text-gray-500 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white text-sm font-medium transition flex items-center gap-1">
                                @(currentCulture == "en" ? "EN" : currentCulture == "el" ? "ΕΛ" : "عر")
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </button>
                            <div id="lang-dropdown" class="hidden absolute right-0 mt-2 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg shadow-lg py-1 z-50 min-w-[120px]">
                                <a href="/set-language/en" class="block px-4 py-2 text-sm text-gray-700 dark:text-slate-300 hover:bg-gray-100 dark:hover:bg-slate-700 @(currentCulture == "en" ? "font-bold" : "")">English</a>
                                <a href="/set-language/el" class="block px-4 py-2 text-sm text-gray-700 dark:text-slate-300 hover:bg-gray-100 dark:hover:bg-slate-700 @(currentCulture == "el" ? "font-bold" : "")">Ελληνικά</a>
                                <a href="/set-language/ar" class="block px-4 py-2 text-sm text-gray-700 dark:text-slate-300 hover:bg-gray-100 dark:hover:bg-slate-700 @(currentCulture == "ar" ? "font-bold" : "")" dir="rtl">العربية</a>
                            </div>
                        </div>

                        <!-- Theme Toggle -->
                        <button id="theme-toggle" type="button"
                                class="text-gray-500 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white transition"
                                title="Toggle theme">
                            <!-- Sun icon (shown in dark mode) -->
                            <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                            </svg>
                            <!-- Moon icon (shown in light mode) -->
                            <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                            </svg>
                        </button>

                        <a asp-page="/Cart/Index" class="text-gray-600 dark:text-slate-300 hover:text-gray-900 dark:hover:text-white relative flex items-center gap-1">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
                            </svg>
                            @{
                                var cartCount = Cart.GetCartCount();
                            }
                            @if (cartCount > 0)
                            {
                                <span class="bg-indigo-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center">@cartCount</span>
                            }
                        </a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-page="/Account/Profile" class="text-gray-600 dark:text-slate-300 hover:text-gray-900 dark:hover:text-white text-sm font-medium">@L["Profile"]</a>
                            <a asp-page="/Account/Orders" class="text-gray-600 dark:text-slate-300 hover:text-gray-900 dark:hover:text-white text-sm font-medium">@L["Orders"]</a>
                            <form method="post" asp-page="/Account/Logout" class="inline">
                                <button type="submit" class="text-gray-600 dark:text-slate-300 hover:text-gray-900 dark:hover:text-white text-sm font-medium">@L["Logout"]</button>
                            </form>
                        }
                        else
                        {
                            <a asp-page="/Account/Login" class="text-gray-600 dark:text-slate-300 hover:text-gray-900 dark:hover:text-white text-sm font-medium">@L["Login"]</a>
                            <a asp-page="/Account/Register" class="bg-indigo-500 hover:bg-indigo-600 text-white text-sm font-medium px-3 py-1.5 rounded-lg transition">@L["Register"]</a>
                        }
                    </div>
                </div>
            </div>
        </nav>

        <main class="flex-1">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
                @RenderBody()
            </div>
        </main>

        <footer class="bg-white dark:bg-slate-800 border-t border-gray-200 dark:border-slate-700 transition-colors duration-300">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
                <p class="text-center text-gray-500 dark:text-slate-400 text-sm">&copy; 2026 EShop - ASP.NET Core Learning Project</p>
            </div>
        </footer>
    </div>

    <script>
        document.getElementById('theme-toggle').addEventListener('click', function() {
            const html = document.documentElement;
            if (html.classList.contains('dark')) {
                html.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                html.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
        });
        // Close language dropdown on click outside
        document.addEventListener('click', function(e) {
            const menu = document.getElementById('lang-menu');
            const dropdown = document.getElementById('lang-dropdown');
            if (menu && dropdown && !menu.contains(e.target)) {
                dropdown.classList.add('hidden');
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
