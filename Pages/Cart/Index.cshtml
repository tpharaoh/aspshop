@page
@model aspshop.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="space-y-6">
    <h1 class="text-3xl font-bold text-white">Shopping Cart</h1>

    @if (!Model.CartItems.Any())
    {
        <div class="text-center py-12 space-y-4">
            <p class="text-slate-400 text-lg">Your cart is empty.</p>
            <a asp-page="/Products/Index" class="inline-block bg-indigo-500 hover:bg-indigo-600 text-white font-semibold px-6 py-3 rounded-lg transition">
                Browse Products
            </a>
        </div>
    }
    else
    {
        <div class="bg-slate-800 border border-slate-700 rounded-lg divide-y divide-slate-700">
            @foreach (var item in Model.CartItems)
            {
                <div class="flex items-center justify-between p-4">
                    <div class="flex items-center gap-4">
                        <div class="w-16 h-16 bg-slate-700 rounded flex items-center justify-center flex-shrink-0">
                            <svg class="w-8 h-8 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-semibold text-white">@item.Name</h3>
                            <p class="text-sm text-slate-400">$@item.Price.ToString("F2") each</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <form method="post" asp-page-handler="Update" class="flex items-center gap-2">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                    class="w-8 h-8 rounded bg-slate-700 hover:bg-slate-600 text-white text-sm transition">-</button>
                            <span class="text-white w-8 text-center">@item.Quantity</span>
                            <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                    class="w-8 h-8 rounded bg-slate-700 hover:bg-slate-600 text-white text-sm transition">+</button>
                        </form>
                        <span class="text-emerald-400 font-bold w-20 text-right">$@((item.Price * item.Quantity).ToString("F2"))</span>
                        <form method="post" asp-page-handler="Remove">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="text-red-400 hover:text-red-300 text-sm transition">Remove</button>
                        </form>
                    </div>
                </div>
            }
        </div>

        <!-- Cart Total -->
        <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
            <div class="flex items-center justify-between mb-4">
                <span class="text-lg text-slate-300">Total</span>
                <span class="text-2xl font-bold text-emerald-400">$@Model.CartTotal.ToString("F2")</span>
            </div>
            <div class="flex gap-4">
                <a asp-page="/Products/Index" class="flex-1 text-center border border-slate-600 hover:border-slate-500 text-slate-300 py-3 rounded-lg transition">
                    Continue Shopping
                </a>
                <a asp-page="/Checkout/Index" class="flex-1 text-center bg-indigo-500 hover:bg-indigo-600 text-white font-semibold py-3 rounded-lg transition">
                    Checkout
                </a>
            </div>
        </div>
    }
</div>
