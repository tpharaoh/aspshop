@page
@model aspshop.Pages.Cart.IndexModel
@{
    ViewData["Title"] = L["ShoppingCart"].Value;
}

<div class="space-y-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">@L["ShoppingCart"]</h1>

    @if (!Model.CartItems.Any())
    {
        <div class="text-center py-12 space-y-4">
            <p class="text-gray-500 dark:text-slate-400 text-lg">@L["CartEmpty"]</p>
            <a asp-page="/Products/Index" class="inline-block bg-indigo-500 hover:bg-indigo-600 text-white font-semibold px-6 py-3 rounded-lg transition">
                @L["BrowseProducts"]
            </a>
        </div>
    }
    else
    {
        <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg divide-y divide-gray-200 dark:divide-slate-700">
            @foreach (var item in Model.CartItems)
            {
                <div class="flex items-center justify-between p-4">
                    <div class="flex items-center gap-4">
                        <div class="w-16 h-16 bg-gray-100 dark:bg-slate-700 rounded flex items-center justify-center flex-shrink-0">
                            <svg class="w-8 h-8 text-gray-300 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-900 dark:text-white">@item.Name</h3>
                            <p class="text-sm text-gray-500 dark:text-slate-400">$@item.Price.ToString("F2")</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <form method="post" asp-page-handler="Update" class="flex items-center gap-2">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                    class="w-8 h-8 rounded bg-gray-100 dark:bg-slate-700 hover:bg-gray-200 dark:hover:bg-slate-600 text-gray-700 dark:text-white text-sm transition">-</button>
                            <span class="text-gray-900 dark:text-white w-8 text-center">@item.Quantity</span>
                            <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                    class="w-8 h-8 rounded bg-gray-100 dark:bg-slate-700 hover:bg-gray-200 dark:hover:bg-slate-600 text-gray-700 dark:text-white text-sm transition">+</button>
                        </form>
                        <span class="text-emerald-600 dark:text-emerald-400 font-bold w-20 text-right">$@((item.Price * item.Quantity).ToString("F2"))</span>
                        <form method="post" asp-page-handler="Remove">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="text-red-500 dark:text-red-400 hover:text-red-700 dark:hover:text-red-300 text-sm transition">@L["Remove"]</button>
                        </form>
                    </div>
                </div>
            }
        </div>

        <!-- Social Share Discount -->
        @if (!Model.HasDiscount)
        {
            <div class="bg-gradient-to-r from-indigo-500/10 to-purple-500/10 border border-indigo-500/30 rounded-lg p-6 text-center space-y-3">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">@L["ShareAndSave"]</h3>
                <p class="text-sm text-gray-500 dark:text-slate-400">@L["ShareDescription"]</p>
                <div class="flex justify-center gap-3">
                    <button onclick="shareAndDiscount('facebook')"
                            class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition flex items-center gap-2">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                        Facebook
                    </button>
                    <button onclick="shareAndDiscount('twitter')"
                            class="bg-sky-500 hover:bg-sky-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition flex items-center gap-2">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
                        Twitter
                    </button>
                    <button onclick="shareAndDiscount('whatsapp')"
                            class="bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition flex items-center gap-2">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        WhatsApp
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="bg-emerald-500/10 border border-emerald-500/30 rounded-lg p-4 flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-emerald-600 dark:text-emerald-400 font-medium">@L["DiscountApplied"]</span>
                </div>
                <span class="text-emerald-600 dark:text-emerald-400 font-bold">-10%</span>
            </div>
        }

        <!-- Complete Your Setup -->
        @if (Model.Suggestions.Any())
        {
            <div class="space-y-3">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white">@L["CompleteYourSetup"]</h2>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                    @foreach (var rec in Model.Suggestions)
                    {
                        <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-3 hover:border-indigo-500 transition">
                            <a asp-page="/Products/Detail" asp-route-id="@rec.Id">
                                <div class="h-20 bg-gray-100 dark:bg-slate-700 rounded flex items-center justify-center mb-2">
                                    <svg class="w-8 h-8 text-gray-300 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                    </svg>
                                </div>
                                <h3 class="text-xs font-semibold text-gray-900 dark:text-white truncate">@rec.Name</h3>
                                <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400 mt-1">$@rec.Price.ToString("F2")</p>
                            </a>
                            <form method="post" asp-page-handler="AddSuggestion" class="mt-2">
                                <input type="hidden" name="productId" value="@rec.Id" />
                                <button type="submit" class="w-full text-xs bg-indigo-500 hover:bg-indigo-600 text-white py-1.5 rounded transition">
                                    @L["AddToCart"]
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Cart Total -->
        <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 space-y-3">
            <div class="flex items-center justify-between">
                <span class="text-gray-500 dark:text-slate-400">@L["Subtotal"]</span>
                <span class="text-gray-700 dark:text-slate-300">$@Model.CartSubtotal.ToString("F2")</span>
            </div>
            @if (Model.HasDiscount)
            {
                <div class="flex items-center justify-between text-emerald-600 dark:text-emerald-400">
                    <span>@L["DiscountApplied"] (10%)</span>
                    <span>-$@Model.DiscountAmount.ToString("F2")</span>
                </div>
            }
            <div class="border-t border-gray-200 dark:border-slate-700 pt-3 flex items-center justify-between">
                <span class="text-lg font-semibold text-gray-900 dark:text-white">@L["Total"]</span>
                <span class="text-2xl font-bold text-emerald-600 dark:text-emerald-400">$@Model.CartTotal.ToString("F2")</span>
            </div>
            <div class="flex gap-4 pt-2">
                <a asp-page="/Products/Index" class="flex-1 text-center border border-gray-300 dark:border-slate-600 hover:border-gray-400 dark:hover:border-slate-500 text-gray-600 dark:text-slate-300 py-3 rounded-lg transition">
                    @L["ContinueShopping"]
                </a>
                <a asp-page="/Checkout/Index" class="flex-1 text-center bg-indigo-500 hover:bg-indigo-600 text-white font-semibold py-3 rounded-lg transition">
                    @L["Checkout"]
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    function shareAndDiscount(platform) {
        const text = "Check out these amazing deals on EShop!";
        const url = window.location.origin;
        let shareUrl;

        switch(platform) {
            case 'facebook':
                shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
                break;
            case 'twitter':
                shareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`;
                break;
            case 'whatsapp':
                shareUrl = `https://wa.me/?text=${encodeURIComponent(text + ' ' + url)}`;
                break;
        }

        // Open share window
        window.open(shareUrl, '_blank', 'width=600,height=400');

        // Apply discount after sharing (simulated confirmation)
        setTimeout(function() {
            // POST to apply discount
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '?handler=ApplyDiscount';
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = '__RequestVerificationToken';
                input.value = token.value;
                form.appendChild(input);
            }
            document.body.appendChild(form);
            form.submit();
        }, 2000);
    }
</script>
}
