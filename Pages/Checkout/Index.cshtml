@page
@model aspshop.Pages.Checkout.IndexModel
@{
    ViewData["Title"] = L["Checkout"].Value;
}

<div class="max-w-2xl mx-auto space-y-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">@L["Checkout"]</h1>

    @if (!Model.CartItems.Any())
    {
        <div class="text-center py-12">
            <p class="text-gray-500 dark:text-slate-400">Your cart is empty.</p>
            <a asp-page="/Products/Index" class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300 mt-2 inline-block">Browse Products</a>
        </div>
    }
    else
    {
        <!-- Order Summary -->
        <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 space-y-3">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">@L["OrderSummary"]</h2>
            @foreach (var item in Model.CartItems)
            {
                <div class="flex justify-between text-sm">
                    <span class="text-gray-600 dark:text-slate-300">@item.Name x @item.Quantity</span>
                    <span class="text-gray-600 dark:text-slate-300">$@((item.Price * item.Quantity).ToString("F2"))</span>
                </div>
            }
            @if (Model.HasDiscount)
            {
                <div class="border-t border-gray-200 dark:border-slate-700 pt-3 flex justify-between text-sm">
                    <span class="text-gray-500 dark:text-slate-400">Subtotal</span>
                    <span class="text-gray-500 dark:text-slate-400">$@Model.CartSubtotal.ToString("F2")</span>
                </div>
                <div class="flex justify-between text-sm text-emerald-600 dark:text-emerald-400">
                    <span>Social share discount (10%)</span>
                    <span>-$@Model.DiscountAmount.ToString("F2")</span>
                </div>
            }
            <div class="border-t border-gray-200 dark:border-slate-700 pt-3 flex justify-between">
                <span class="text-lg font-semibold text-gray-900 dark:text-white">@L["Total"]</span>
                <span class="text-lg font-bold text-emerald-600 dark:text-emerald-400">$@Model.CartTotal.ToString("F2")</span>
            </div>
        </div>

        <!-- Shipping Info (Mock) -->
        <form method="post" class="space-y-6">
            <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 space-y-4">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white">@L["ShippingInformation"]</h2>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">First Name</label>
                        <input type="text" name="firstName" required
                               class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500" />
                    </div>
                    <div>
                        <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">Last Name</label>
                        <input type="text" name="lastName" required
                               class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500" />
                    </div>
                </div>
                <div>
                    <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">Email</label>
                    <input type="email" name="email" required
                           class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500" />
                </div>
                <div>
                    <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">Address</label>
                    <input type="text" name="address" required
                           class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500" />
                </div>
                <div class="grid grid-cols-3 gap-4">
                    <div>
                        <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">City</label>
                        <input type="text" name="city" required
                               class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500" />
                    </div>
                    <div>
                        <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">State</label>
                        <input type="text" name="state" required
                               class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500" />
                    </div>
                    <div>
                        <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">Zip Code</label>
                        <input type="text" name="zip" required
                               class="w-full bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-900 dark:text-slate-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-indigo-500" />
                    </div>
                </div>
            </div>

            <!-- Payment (Mock) -->
            <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 space-y-4">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white">@L["PaymentDemo"]</h2>
                <p class="text-sm text-gray-500 dark:text-slate-400">@L["MockPaymentNote"]</p>
                <div>
                    <label class="block text-sm text-gray-500 dark:text-slate-400 mb-1">Card Number</label>
                    <input type="text" value="4242 4242 4242 4242" readonly
                           class="w-full bg-gray-100 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 text-gray-400 dark:text-slate-500 rounded-lg px-4 py-2 text-sm" />
                </div>
            </div>

            <button type="submit"
                    class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-semibold py-3 rounded-lg transition text-lg">
                @L["PlaceOrder"] - $@Model.CartTotal.ToString("F2")
            </button>
        </form>
    }
</div>
